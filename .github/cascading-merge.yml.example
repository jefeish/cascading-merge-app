# ═══════════════════════════════════════════════════════════════════════════
# Cascading Merge App - Repository Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# WHAT THIS FILE DOES:
# This configuration file controls how the Cascading Merge App behaves in
# YOUR repository. Each repository that has the app installed can have its
# own cascading-merge.yml with custom settings.
#
# HOW THE APP USES THIS FILE:
# 1. When ANY pull request is closed in your repository (merged or not)
# 2. The app checks if the PR was merged by a human (bot PRs are ignored)
# 3. The app reads THIS file from .github/cascading-merge.yml
# 4. If this file doesn't exist, default settings are used:
#    - prefixes: ['release/']
#    - ref_branch: 'develop'
#
# LOCATION:
# Place this file at: .github/cascading-merge.yml
# (Remove the .example extension)
#
# ═══════════════════════════════════════════════════════════════════════════

# Branch prefixes to include in the cascade
# When a PR is merged to a branch matching any of these prefixes,
# the app will create PRs to merge into subsequent branches
prefixes:
  - 'release/'
  - 'hotfix/'

# The final branch to merge into
# This is the last branch in the cascade sequence
ref_branch: 'main'

# Enable verbose reporting (optional)
# When true, creates a GitHub Issue with:
# - Details of the original PR that triggered the cascade
# - A table of all cascade PRs created
# - A Mermaid diagram visualizing the cascade flow
# Default: false
verbose: true

# --- How It Works ---
#
# Example branch structure:
#   release/1.0
#   release/1.1
#   release/2.0
#   main
#
# When you merge a PR into release/1.0:
# 1. App creates PR: release/1.0 → release/1.1
# 2. If no conflicts, auto-merges
# 3. App creates PR: release/1.1 → release/2.0
# 4. If no conflicts, auto-merges
# 5. App creates PR: release/2.0 → main
# 6. If no conflicts, auto-merges
#
# If a merge fails due to conflicts:
# - The cascade stops at that point
# - An issue is created and assigned to the PR author
# - A comment is added to the original PR

# --- Branch Ordering ---
#
# Branches are ordered using semantic version sorting.
# Examples of correctly ordered branches:
#
#   release/1.0
#   release/1.1
#   release/1.1-1
#   release/1.1-2
#   release/1.1-3
#   release/1.1-rc1
#   release/1.2-a
#   release/1.2-b
#   release/1.3
#   release/2.0
#
# The algorithm handles:
# - Major.minor versions (1.0, 2.0)
# - Patch versions (1.1-1, 1.1-2)
# - Pre-release tags (1.1-rc1, 1.2-alpha)
# - Custom suffixes (1.2-a, 1.2-b)
