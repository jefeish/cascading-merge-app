# ============================================
# GitHub App Configuration (REQUIRED)
# ============================================

# The ID of your GitHub App (found in App settings)
APP_ID=

# A random string used to verify GitHub webhooks
# Generate with: openssl rand -hex 20
WEBHOOK_SECRET=

# The path to a private key file (generate via GitHub App settings)
# Option 1: Use file path
PRIVATE_KEY_PATH=

# Option 2: Use private key directly (for cloud deployments)
# Uncomment and paste your private key between the quotes
# PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
# ...
# -----END RSA PRIVATE KEY-----"

# ============================================
# Optional Configuration
# ============================================

# GitHub Client credentials (optional, for OAuth)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Webhook proxy for local development (use smee.io or ngrok)
# WEBHOOK_PROXY_URL=https://smee.io/your-channel-id

# ============================================
# Logging & Environment
# ============================================

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Log format: pretty (development) or json (production)
# LOG_FORMAT=pretty

# Environment: development or production
NODE_ENV=development

# Server port (default: 3000)
# PORT=3000

# ============================================
# Advanced Configuration
# ============================================

# Behavior when .github/cascading-merge.yml is missing or invalid
# Options:
#   - "use-defaults" (default): Use default settings (prefixes=['release/'], ref_branch='develop')
#   - "skip": Skip cascade merge for repos without a config file (recommended for multi-repo installations)
# MISSING_CONFIG_BEHAVIOR=use-defaults

# GitHub API timeout in milliseconds (default: 30000)
# GITHUB_API_TIMEOUT=30000

# Maximum number of API retry attempts (default: 3)
# MAX_RETRIES=3

# ============================================
# Production Notes
# ============================================
# 
# 1. Never commit .env file with actual secrets
# 2. Use secrets management in production:
#    - Docker secrets
#    - Kubernetes secrets
#    - Cloud provider secret managers (AWS Secrets Manager, Azure Key Vault, etc.)
# 3. Set NODE_ENV=production in production
# 4. Use LOG_FORMAT=json for structured logging
# 5. See docs/DEPLOYMENT.md for deployment guide
